# =============================================================================
# BNP (Be Nice Properties) — environment variables
# Copy to .env and fill in. NEVER commit .env. NEVER paste secret values anywhere.
# =============================================================================

# --- Server ---
NODE_ENV=development
PORT=5060
HOST=127.0.0.1

# --- Database (BNP's own thin Neon Postgres) ---
# Point at a Neon TEST BRANCH for development. Do not run migrations against a
# production branch without explicit confirmation.
DATABASE_URL=postgresql://user:password@host.neon.tech/bnp?sslmode=require

# --- Session / admin auth ---
SESSION_SECRET=change-me-to-a-long-random-string
# Bootstrap admin (Phase 5 admin login). Password is hashed at rest.
ADMIN_EMAIL=admin@beniceproperties.com
ADMIN_PASSWORD=change-me

# --- Stripe (TEST MODE until go-live is confirmed) ---
# Use sk_test_... / pk_test_... here. Flip to sk_live_.../pk_live_... only when ready.
STRIPE_SECRET_KEY=sk_test_xxx
VITE_STRIPE_PUBLIC_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Stripe Price id for the weekly co-living rent subscription (test mode).
# STRIPE_WEEKLY_PRICE_ID=price_xxx   # created in Phase 4

# --- Manual payment methods (no API; shown to guest as instructions) ---
CASHAPP_TAG=$BeNiceProperties
ZELLE_HANDLE=pay@beniceproperties.com

# --- UO → BNP integration API (Phase 8): UO consumes BNP's /api/uo/* surface ---
# Shared service token UO sends as `Authorization: Bearer <token>`. If unset, the
# /api/uo/* surface is DISABLED (fail closed). Generate a long random string.
UO_BNP_API_TOKEN=change-me-long-random-service-token

# --- Email (Phase 5/7): SendGrid SMTP OR generic SMTP. Unset = dry-run + log. ---
# SENDGRID_API_KEY=SG.xxx
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=xxx
# MAIL_FROM=no-reply@beniceproperties.com

# --- SMS (Phase 5/7): Twilio. Unset = dry-run + log. ---
# TWILIO_ACCOUNT_SID=ACxxx
# TWILIO_AUTH_TOKEN=xxx
# TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# --- Analytics: PostHog ---
# Server-side (posthog-node): backend event capture + exception autocapture.
POSTHOG_API_KEY=phc_xxx
POSTHOG_HOST=https://us.i.posthog.com
# Client-side (posthog-js): pageviews, session replay, conversion events. Use the
# SAME project key as POSTHOG_API_KEY so client + server land in one project.
# The phc_ key is a public/write-only key — safe in the browser bundle. If unset,
# client analytics no-ops (no errors).
VITE_POSTHOG_KEY=phc_xxx
VITE_POSTHOG_HOST=https://us.i.posthog.com

# --- Unified Ops rollup push (STUBBED until UO ships /api/integration) ---
# Endpoint is a placeholder; the push module logs a dry-run payload until wired.
UO_ENDPOINT=https://unified-ops.example/api/integration/kpi
UO_SERVICE_TOKEN=change-me-shared-secret
# Set to "true" to actually POST; leave unset/false for dry-run logging only.
UO_PUSH_ENABLED=false
